---
import 'aos/dist/aos.css';
import { getCollection } from 'astro:content';
import { BLOG_PAGE } from '../../config';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { withBase } from '../../utils/base';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<SiteLayout title={BLOG_PAGE.title} description={BLOG_PAGE.description}>
  <section class="blog-list blog-list-minimal" data-aos="fade-up">
    <p class="eyebrow">{BLOG_PAGE.eyebrow}</p>
    <h2>{BLOG_PAGE.heading}</h2>
    <div class="blog-minimal">
      {
        posts.map((post, index) => (
          <article
            class="blog-row"
            data-aos="fade-up"
            data-aos-delay={Math.min(index * 70, 280)}
          >
            <p class="meta">
              {post.data.pubDate.toLocaleDateString()} • {post.data.author}
            </p>
            <h3>
              <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
            </h3>
            <p class="blog-excerpt">{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <script>
    import AOS from 'aos';

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    const initAos = () => {
      if (prefersReducedMotion) return;
      if (!document.querySelector('[data-aos]')) return;
      AOS.init({
        duration: 680,
        easing: 'ease-out-cubic',
        once: true,
        offset: 18,
      });
    };

    initAos();
    document.addEventListener('astro:page-load', initAos);
  </script>
</SiteLayout>
