---
import { EVENT_CADENCE, EVENT_FORMATS, EVENTS_CONTENT, EVENTS_PAGE } from '../config';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title={EVENTS_PAGE.title} description={EVENTS_PAGE.description}>
	<section class="page-hero">
		<p class="eyebrow">{EVENTS_PAGE.eyebrow}</p>
		<h1>{EVENTS_PAGE.heading}</h1>
		<p class="lead">{EVENTS_PAGE.lead}</p>
	</section>

	<section class="page-list">
		<p class="eyebrow">{EVENTS_CONTENT.formatsEyebrow}</p>
		<h2>{EVENTS_CONTENT.formatsHeading}</h2>
		<ol>
			{
				EVENT_FORMATS.map((format) => (
					<li>{format}</li>
				))
			}
		</ol>
	</section>

	<section class="page-content">
		<p class="eyebrow">{EVENTS_CONTENT.cadenceEyebrow}</p>
		<h2>{EVENTS_CONTENT.cadenceHeading}</h2>
		<div class="two-col-list">
			<ul>
				{EVENT_CADENCE.left.map((item) => <li>{item}</li>)}
			</ul>
			<ul>
				{EVENT_CADENCE.right.map((item) => <li>{item}</li>)}
			</ul>
		</div>
	</section>

	<section class="page-cta">
		<p class="eyebrow">{EVENTS_CONTENT.joinEyebrow}</p>
		<h2>{EVENTS_CONTENT.joinHeading}</h2>
		<div class="cta-row">
			<a class="btn btn-primary" href="/join">{EVENTS_CONTENT.joinPrimaryLabel}</a>
			<a class="btn btn-alt" href="/blog">{EVENTS_CONTENT.joinSecondaryLabel}</a>
		</div>
	</section>
</SiteLayout>
