---
import { ABOUT_CONTENT, ABOUT_PAGE, ABOUT_PRINCIPLES } from '../config';
import SiteLayout from '../layouts/SiteLayout.astro';
import { withBase } from '../utils/base';
---

<SiteLayout title={ABOUT_PAGE.title} description={ABOUT_PAGE.description}>
  <section class="page-hero">
    <p class="eyebrow">{ABOUT_PAGE.eyebrow}</p>
    <h1>{ABOUT_PAGE.heading}</h1>
    <p class="lead">{ABOUT_PAGE.lead}</p>
  </section>

  <section class="page-content about-mission">
    <p class="eyebrow">{ABOUT_CONTENT.missionEyebrow}</p>
    <h2>{ABOUT_CONTENT.missionHeading}</h2>
    <p class="lead">{ABOUT_CONTENT.missionLead}</p>
  </section>

  <section class="page-list about-principles">
    <p class="eyebrow">{ABOUT_CONTENT.principlesEyebrow}</p>
    <h2>{ABOUT_CONTENT.principlesHeading}</h2>
    <div class="principle-grid">
      {
        ABOUT_PRINCIPLES.map((item, index) => (
          <article class="principle-item">
            <p class="principle-index">0{index + 1}</p>
            <p>{item}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-content about-flow">
    <p class="eyebrow">Club Rhythm</p>
    <h2>WEEKLY CYCLE THAT KEEPS YOU SHARP</h2>
    <ul class="flow-line">
      <li>Kickoff: choose a tiny problem</li>
      <li>Midweek: pair-debug and review</li>
      <li>Weekend: demo what you shipped</li>
    </ul>
  </section>

  <section class="page-cta">
    <p class="eyebrow">{ABOUT_CONTENT.exploreEyebrow}</p>
    <h2>{ABOUT_CONTENT.exploreHeading}</h2>
    <div class="cta-row">
      <a class="btn btn-primary" href={withBase('/join')}
        >{ABOUT_CONTENT.explorePrimaryLabel}</a
      >
      <a class="btn btn-alt" href={withBase('/blog')}
        >{ABOUT_CONTENT.exploreSecondaryLabel}</a
      >
    </div>
  </section>
</SiteLayout>
