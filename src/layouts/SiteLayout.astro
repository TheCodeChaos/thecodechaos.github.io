---
import { ClientRouter } from 'astro:transitions';
import { NAV_LINKS, SITE, SOCIALS } from '../config';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import '../styles/site.css';
import { withBase } from '../utils/base';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${SITE.title} | Open Coding Club for Students`,
  description = SITE.description,
  ogImage,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonicalURL = new URL(pathname, SITE.website).href;
const defaultOgPath =
  pathname === '/'
    ? `/${SITE.ogImage}`
    : `${pathname.replace(/\/$/, '')}/og.png`;
const socialImageURL = new URL(ogImage ?? defaultOgPath, SITE.website).href;
const activeSocials = SOCIALS.filter((social) => social.active);
const currentYear = new Date().getFullYear();
const hasPagefindAssets = import.meta.env.PROD;
const pagefindUiScriptSrc = withBase('/pagefind/pagefind-ui.js');
const pagefindUiStylesHref = withBase('/pagefind/pagefind-ui.css');
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.title} RSS`}
      href={withBase('/rss.xml')}
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
    <meta name="theme-color" content="#0c1025" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Manrope:wght@400;600;700;800&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    {hasPagefindAssets && <link rel="stylesheet" href={pagefindUiStylesHref} />}
    <title>{title}</title>
    <script is:inline>
      (() => {
        const key = `codechaos-scroll:${window.location.pathname}`;
        const root = document.documentElement;
        const readSavedScroll = () => {
          const saved = sessionStorage.getItem(key);
          if (!saved) return null;
          const y = Number(saved);
          if (!Number.isFinite(y) || y <= 0) return null;
          return y;
        };

        const initialY = readSavedScroll();
        if (initialY !== null) {
          root.classList.add('scroll-restoring');
        }

        const restoreScroll = () => {
          const y = readSavedScroll();
          if (y === null) return;
          window.scrollTo(0, y);
        };

        if ('scrollRestoration' in history) {
          history.scrollRestoration = 'manual';
        }

        restoreScroll();
        window.addEventListener(
          'load',
          () => {
            restoreScroll();
            requestAnimationFrame(() => {
              root.classList.remove('scroll-restoring');
            });
          },
          { once: true }
        );

        const saveScroll = () => {
          sessionStorage.setItem(key, String(window.scrollY));
        };

        window.addEventListener('beforeunload', saveScroll);
        window.addEventListener('pagehide', saveScroll);
      })();
    </script>
    <script is:inline>
      (() => {
        const key = 'codechaos-theme';
        const stored = localStorage.getItem(key);
        const systemDark = window.matchMedia(
          '(prefers-color-scheme: dark)'
        ).matches;
        const theme = stored || (systemDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <ClientRouter />
    <div class="noise-overlay" aria-hidden="true"></div>

    <SiteHeader navLinks={NAV_LINKS} site={SITE} pathname={pathname} />

    <main class="site-main">
      <slot />
    </main>

    <div
      id="search-modal"
      class="search-modal"
      hidden
      data-pagefind-enabled={hasPagefindAssets ? 'true' : 'false'}
      data-pagefind-ui-src={pagefindUiScriptSrc}
    >
      <button
        class="search-backdrop"
        type="button"
        aria-label="Close search"
        data-close-search></button>

      <section class="search-panel" role="dialog" aria-modal="true">
        <div class="search-panel-head">
          <p class="search-panel-title">Search CodeChaos</p>
          <button
            class="search-close"
            type="button"
            aria-label="Close search"
            data-close-search
          >
            Close
          </button>
        </div>

        <div id="search-ui" class="search-ui"></div>
      </section>
    </div>

    <SiteFooter site={SITE} socials={activeSocials} year={currentYear} />

    <script is:inline>
      (() => {
        const key = 'codechaos-theme';
        const root = document.documentElement;
        const getTheme = () => {
          const stored = localStorage.getItem(key);
          if (stored === 'light' || stored === 'dark') {
            return stored;
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        };

        const applyTheme = (theme) => {
          root.setAttribute('data-theme', theme);
        };

        const syncButtonLabel = (btn) => {
          const current = root.getAttribute('data-theme') || 'dark';
          if (btn) {
            btn.setAttribute(
              'aria-label',
              current === 'dark'
                ? 'Switch to light mode'
                : 'Switch to dark mode'
            );
            btn.setAttribute(
              'title',
              current === 'dark'
                ? 'Switch to light mode'
                : 'Switch to dark mode'
            );
          }
        };

        const bindToggle = () => {
          const btn = document.getElementById('theme-toggle');
          if (!btn) return;
          btn.onclick = () => {
            const current = root.getAttribute('data-theme') || 'dark';
            const next = current === 'dark' ? 'light' : 'dark';
            localStorage.setItem(key, next);
            applyTheme(next);
            syncButtonLabel(btn);
          };
          syncButtonLabel(btn);
        };

        const bindMenu = () => {
          const btn = document.getElementById('menu-toggle');
          const nav = document.getElementById('site-nav');
          if (!btn || !nav) return;

          const setOpen = (open) => {
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            nav.classList.toggle('is-open', open);
          };

          btn.onclick = () => {
            const open = btn.getAttribute('aria-expanded') !== 'true';
            setOpen(open);
          };

          nav.querySelectorAll('a').forEach((link) => {
            link.onclick = () => {
              if (window.matchMedia('(max-width: 680px)').matches) {
                setOpen(false);
              }
            };
          });

          if (!window.matchMedia('(max-width: 680px)').matches) {
            setOpen(false);
          }
        };

        const bindSearch = () => {
          const modal = document.getElementById('search-modal');
          const uiRoot = document.getElementById('search-ui');
          if (!modal || !uiRoot) return;

          const w = window;

          const setSearchOpen = (open) => {
            modal.hidden = !open;
            document.body.classList.toggle('search-open', open);

            if (!open) return;

            void initSearchUi();
            window.setTimeout(() => {
              const input = modal.querySelector('.pagefind-ui__search-input');
              if (input instanceof HTMLInputElement) {
                input.focus();
              }
            }, 40);
          };

          const loadPagefindUi = async () => {
            const enabled = modal.getAttribute('data-pagefind-enabled');
            if (enabled !== 'true') {
              throw new Error('Pagefind assets are disabled in dev mode');
            }

            if (w.PagefindUI) return;

            const existing = document.querySelector(
              'script[data-pagefind-ui="true"]'
            );

            if (existing) {
              await new Promise((resolve, reject) => {
                existing.addEventListener('load', resolve, { once: true });
                existing.addEventListener('error', reject, { once: true });
              });
              return;
            }

            const src = modal.getAttribute('data-pagefind-ui-src');
            if (!src) return;

            await new Promise((resolve, reject) => {
              const script = document.createElement('script');
              script.src = src;
              script.defer = true;
              script.dataset.pagefindUi = 'true';
              script.onload = resolve;
              script.onerror = reject;
              document.head.appendChild(script);
            });
          };

          const initSearchUi = async () => {
            if (uiRoot.getAttribute('data-pagefind-ready') === 'true') return;

            uiRoot.setAttribute('data-pagefind-ready', 'loading');

            try {
              await loadPagefindUi();

              if (!w.PagefindUI) {
                throw new Error('Pagefind UI is unavailable');
              }

              uiRoot.innerHTML = '';

              new w.PagefindUI({
                element: '#search-ui',
                showImages: false,
                showSubResults: true,
                resetStyles: false,
                excerptLength: 16,
                translations: {
                  placeholder: 'Search posts, pages, and updates',
                },
              });

              uiRoot.setAttribute('data-pagefind-ready', 'true');
            } catch {
              uiRoot.innerHTML =
                '<p class="search-error">Search index is not available yet. Run a production build to generate Pagefind files.</p>';
              uiRoot.setAttribute('data-pagefind-ready', 'error');
            }
          };

          document.querySelectorAll('[data-open-search]').forEach((button) => {
            button.onclick = () => {
              setSearchOpen(true);
            };
          });

          modal.querySelectorAll('[data-close-search]').forEach((button) => {
            button.onclick = () => {
              setSearchOpen(false);
            };
          });

          if (!w.__codechaosSearchEscBound) {
            w.__codechaosSearchEscBound = true;
            document.addEventListener('keydown', (event) => {
              if (event.key !== 'Escape') return;
              const activeModal = document.getElementById('search-modal');
              if (!activeModal || activeModal.hidden) return;
              activeModal.hidden = true;
              document.body.classList.remove('search-open');
            });
          }
        };

        const syncThemeOnNavigation = () => {
          applyTheme(getTheme());
          bindToggle();
          bindMenu();
          bindSearch();
        };

        syncThemeOnNavigation();

        if (!window.__codechaosThemeBound) {
          window.__codechaosThemeBound = true;
          document.addEventListener('astro:page-load', syncThemeOnNavigation);
          document.addEventListener('astro:after-swap', syncThemeOnNavigation);
          document.addEventListener('astro:before-swap', () => {
            const nav = document.getElementById('site-nav');
            const btn = document.getElementById('menu-toggle');
            nav?.classList.remove('is-open');
            btn?.setAttribute('aria-expanded', 'false');

            const modal = document.getElementById('search-modal');
            if (modal) {
              modal.hidden = true;
            }
            document.body.classList.remove('search-open');
          });
        }
      })();
    </script>
  </body>
</html>
